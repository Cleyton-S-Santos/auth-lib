{
  "name": "@cleytonsousa/auth-lib",
  "version": "1.0.0",
  "description": "Biblioteca de autenticação desacoplada (hexagonal) com JWT, refresh, RBAC e ports plugáveis",
  "license": "MIT",
  "type": "module",
  "sideEffects": [
    "**/integrations/request-auth.ts",
    "**/integrations/express/index.ts",
    "**/integrations/nest/index.ts"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.cjs"
      }
    },
    "./express": {
      "import": {
        "types": "./dist/express.d.ts",
        "default": "./dist/express.js"
      },
      "require": {
        "types": "./dist/express.d.cts",
        "default": "./dist/express.cjs"
      }
    },
    "./nest": {
      "import": {
        "types": "./dist/nest.d.ts",
        "default": "./dist/nest.js"
      },
      "require": {
        "types": "./dist/nest.d.ts",
        "default": "./dist/nest.cjs"
      }
    },
    "./adapters/jwt-jose": {
      "import": {
        "types": "./dist/adapters/jwt-jose.d.ts",
        "default": "./dist/adapters/jwt-jose.js"
      },
      "require": {
        "types": "./dist/adapters/jwt-jose.d.ts",
        "default": "./dist/adapters/jwt-jose.cjs"
      }
    },
    "./adapters/crypto-bcrypt": {
      "import": {
        "types": "./dist/adapters/crypto-bcrypt.d.ts",
        "default": "./dist/adapters/crypto-bcrypt.js"
      },
      "require": {
        "types": "./dist/adapters/crypto-bcrypt.d.ts",
        "default": "./dist/adapters/crypto-bcrypt.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "@nestjs/common": "^10.0.0 || ^11.0.0",
    "@nestjs/core": "^10.0.0 || ^11.0.0",
    "express": "^4.18.0 || ^5.0.0",
    "reflect-metadata": "^0.2.0"
  },
  "peerDependenciesMeta": {
    "@nestjs/common": { "optional": true },
    "@nestjs/core": { "optional": true },
    "express": { "optional": true },
    "reflect-metadata": { "optional": true }
  },
  "dependencies": {
    "bcrypt": "^5.1.1",
    "jose": "^5.9.6"
  },
  "devDependencies": {
    "@nestjs/common": "^10.4.15",
    "@nestjs/core": "^10.4.15",
    "@types/bcrypt": "^5.0.2",
    "@types/express": "^4.17.21",
    "@types/node": "^22.10.2",
    "express": "^4.21.2",
    "reflect-metadata": "^0.2.2",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  },
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "auth",
    "jwt",
    "rbac",
    "hexagonal",
    "nestjs",
    "express"
  ]
}
